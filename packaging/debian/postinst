#!/bin/sh
set -e

case "$1" in
    configure)
        setcap cap_net_raw+ep /usr/bin/pping2

        # Dedicated system user, not the shared `nobody` UID — systemd
        # warns on `nobody` (collides with NFS's anonymous UID and any
        # other service also confined to it).
        if ! getent passwd pping2 >/dev/null; then
            adduser --system --group --no-create-home \
                --shell /usr/sbin/nologin pping2
        fi

        mkdir -p /var/log/pping2
        chown pping2:pping2 /var/log/pping2

        # /etc/default/pping2 may hold ClickHouse credentials in CH_AUTH or
        # CH_ARGS. Older pping2 packages shipped this conffile as 0644, and
        # dpkg preserves the on-disk mode across upgrades. Strip "other"
        # bits so credentials added by the admin aren't world-readable.
        # `o-rwx` never grants permission, so admin tightenings (0600) are
        # preserved untouched.
        if [ -e /etc/default/pping2 ]; then
            chmod o-rwx /etc/default/pping2 2>/dev/null || true
        fi

        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
